{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "unitId": { "type": "string" }
      }
    },
    "Unit": {
      "title": "Unit",
      "description": "Church unit or branch",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" }
      }
    },
    "Employee": {
      "title": "Employee",
      "description": "Church employee",
      "type": "object",
      "properties": {
        "employeeName": { "type": "string" },
        "cpf": { "type": "string" },
        "matricula": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "Member": {
      "title": "Member",
      "description": "Church member",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["INCOME", "EXPENSE"] },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "Asset": {
      "title": "Asset",
      "description": "Church asset",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "System users"
    },
    "/units/{unitId}": {
      "schema": { "$ref": "#/entities/Unit" },
      "description": "Church units"
    },
    "/units/{unitId}/employees/{employeeId}": {
      "schema": { "$ref": "#/entities/Employee" },
      "description": "Employees of a unit"
    },
    "/units/{unitId}/members/{memberId}": {
      "schema": { "$ref": "#/entities/Member" },
      "description": "Members of a unit"
    },
    "/units/{unitId}/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Financial transactions of a unit"
    },
    "/units/{unitId}/assets/{assetId}": {
      "schema": { "$ref": "#/entities/Asset" },
      "description": "Assets of a unit"
    },
    "/financial/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Global financial transactions"
    }
  }
}
