rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    // O app usa um sistema de login próprio (IndexedDB), então não podemos
    // depender do Firebase Auth (request.auth) para as regras básicas.
    // Para um ambiente de produção real, o ideal seria integrar o Firebase Auth.
    
    function isAuthenticated() {
      // Temporariamente permitindo acesso para que o app funcione com seu login customizado
      return true;
    }
    
    function isAdmin() {
      // Temporariamente permitindo acesso para que o app funcione com seu login customizado
      return true;
    }

    function isUnitMember(unitId) {
      return true;
    }

    // Allow the test connection document to be read by anyone authenticated
    match /test/connection {
      allow read: if true;
      allow write: if true;
    }

    // Regras para unidades/filiais
    match /units/{unitId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Coleções raiz (filtradas por unitId no app)
    match /employees/{employeeId} {
      allow read, write: if true;
    }
    
    match /members/{memberId} {
      allow read, write: if true;
    }
    
    match /transactions/{transactionId} {
      allow read, write: if true;
    }
    
    match /payables/{payableId} {
      allow read, write: if true;
    }
    
    match /receivables/{receivableId} {
      allow read, write: if true;
    }
    
    match /accounts/{accountId} {
      allow read, write: if true;
    }
    
    match /categories/{categoryId} {
      allow read, write: if true;
    }
    
    match /assets/{assetId} {
      allow read, write: if true;
    }
    
    match /payroll/{payrollId} {
      allow read, write: if true;
    }
    
    match /leaves/{leaveId} {
      allow read, write: if true;
    }
    
    match /timebank/{timebankId} {
      allow read, write: if true;
    }
    
    match /treasury/{documentId} {
      allow read, write: if true;
    }
    
    match /reconciliation/{reconciliationId} {
      allow read, write: if true;
    }
    
    match /reports/{reportId} {
      allow read, write: if true;
    }
    
    match /logs/{logId} {
      allow read, write: if true;
    }
    
    match /financial/transactions/{transactionId} {
      allow read, write: if true;
    }
    
    // Regras para usuários
    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /system_users/{userId} {
      allow read, write: if true;
    }
    
    // Regras para configurações globais
    match /settings/{settingId} {
      allow read, write: if true;
    }
  }
}
