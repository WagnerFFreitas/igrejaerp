# =====================================================
# EXEMPLO DE CONFIGURAÇÃO - copie para .env e ajuste
# =====================================================

# Ambiente
NODE_ENV=development          # development | production | test
PORT=3000
API_PREFIX=/api

# Banco de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=igrejaerp
DB_USER=desenvolvedor
DB_PASSWORD=ALTERE_AQUI

# Pool de Conexões (valores padrão já definidos no código)
DB_POOL_MAX=20                # máx. conexões simultâneas
DB_POOL_MIN=2                 # mín. conexões mantidas abertas
DB_IDLE_TIMEOUT=30000         # ms antes de fechar conexão ociosa
DB_CONN_TIMEOUT=5000          # ms para timeout de nova conexão

# JWT
JWT_SECRET=ALTERE_PARA_SEGREDO_FORTE_EM_PRODUCAO
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGIN=http://localhost:5173
