generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  TRANSITION
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  PAID
  PENDING
}

enum PaymentMethod {
  CASH
  TRANSFER
  CREDIT_CARD
  DEBIT_CARD
  PIX
  CHECK
}

model Unit {
  id           String        @id @default(cuid())
  name         String
  city         String?
  state        String?
  members      Member[]
  accounts     Account[]
  transactions Transaction[]
  assets       Asset[]
  leaves       EmployeeLeave[]
  createdAt    DateTime      @default(now())
}

model Member {
  id         String       @id @default(cuid())
  unitId     String
  unit       Unit         @relation(fields: [unitId], references: [id])
  name       String
  birthDate  DateTime?
  status     MemberStatus @default(ACTIVE)
  role       String?
  avatar     String?
  createdAt  DateTime     @default(now())
}

model Account {
  id             String   @id @default(cuid())
  unitId         String
  unit           Unit     @relation(fields: [unitId], references: [id])
  name           String
  currentBalance Decimal  @db.Decimal(18, 2)
  createdAt      DateTime @default(now())
}

model Transaction {
  id                String           @id @default(cuid())
  unitId            String
  unit              Unit             @relation(fields: [unitId], references: [id])
  date              DateTime
  amount            Decimal          @db.Decimal(18, 2)
  type              TransactionType
  category          String?
  costCenter        String?
  projectId         String?
  status            TransactionStatus @default(PAID)
  paymentMethod     PaymentMethod     @default(CASH)
  isInstallment     Boolean           @default(false)
  installmentsCount Int?
  currentInstallment Int?
  description       String?
  createdAt         DateTime         @default(now())
  createdBy         String?
}

model Asset {
  id             String   @id @default(cuid())
  unitId         String
  unit           Unit     @relation(fields: [unitId], references: [id])
  name           String
  value          Decimal  @db.Decimal(18, 2)
  acquisitionDate DateTime?
  createdAt      DateTime @default(now())
}

model EmployeeLeave {
  id         String   @id @default(cuid())
  unitId     String
  unit       Unit     @relation(fields: [unitId], references: [id])
  employeeId String
  startDate  DateTime
  endDate    DateTime
  reason     String?
  createdAt  DateTime @default(now())
}
