# =====================================================
# EXEMPLO DE CONFIGURAÇÃO FRONTEND - copie para .env
# =====================================================

# Gemini AI (Google)
GEMINI_API_KEY=SUA_CHAVE_AQUI

# URL da API REST (backend Express)
# Em desenvolvimento: proxy do Vite redireciona /api automaticamente
# Em produção: aponte para o domínio real
VITE_API_URL=http://localhost:3000/api

# Nome e versão da aplicação (opcional)
VITE_APP_NAME=ADJPA ERP
VITE_APP_VERSION=1.0.0
